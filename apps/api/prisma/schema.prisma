generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Namespace {
  id              String   @id @default(cuid())
  name            String
  kestraNamespace String
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workflows Workflow[]
  variables Variable[]
  secrets   Secret[]

  @@map("namespaces")
}

model Workflow {
  id               String   @id @default(cuid())
  name             String
  flowId           String
  namespaceId      String
  description      String?
  nodes            Json     @default("[]")
  edges            Json     @default("[]")
  inputs           Json     @default("[]")
  variables        Json     @default("[]")
  disabled         Boolean  @default(false)
  publishedVersion Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  namespace Namespace @relation(fields: [namespaceId], references: [id])
  drafts    WorkflowDraft[]
  releases  WorkflowRelease[]
  executions WorkflowDraftExecution[]
  prodExecutions WorkflowExecution[]
  triggers  WorkflowTrigger[]

  @@unique([namespaceId, flowId])
  @@map("workflows")
}

model WorkflowDraft {
  id         String   @id @default(cuid())
  workflowId String
  nodes      Json
  edges      Json
  inputs     Json
  variables  Json
  message    String?
  createdAt  DateTime @default(now())

  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId, createdAt(sort: Desc)])
  @@map("workflow_drafts")
}

model WorkflowRelease {
  id          String   @id @default(cuid())
  workflowId  String
  version     Int
  name        String
  nodes       Json
  edges       Json
  inputs      Json
  variables   Json
  yaml        String
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, version])
  @@index([workflowId, version(sort: Desc)])
  @@map("workflow_releases")

  executions WorkflowExecution[]
}

model WorkflowDraftExecution {
  id            String    @id @default(cuid())
  workflowId    String
  kestraExecId  String
  nodes         Json
  edges         Json
  inputs        Json
  variables     Json
  inputValues   Json      @default("{}")
  state         String
  taskRuns      Json      @default("[]")
  triggeredBy   String    @default("manual")
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workflow      Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId, createdAt(sort: Desc)])
  @@map("workflow_draft_executions")
}

model WorkflowExecution {
  id            String            @id @default(cuid())
  workflowId    String
  releaseId     String
  kestraExecId  String
  inputValues   Json              @default("{}")
  state         String
  taskRuns      Json              @default("[]")
  triggeredBy   String            @default("manual")
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  workflow      Workflow          @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  release       WorkflowRelease   @relation(fields: [releaseId], references: [id])

  @@index([workflowId, createdAt(sort: Desc)])
  @@index([releaseId])
  @@map("workflow_executions")
}

model WorkflowTrigger {
  id            String   @id @default(cuid())
  workflowId    String
  name          String
  type          String
  config        Json
  inputs        Json     @default("{}")
  kestraFlowId  String
  disabled      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workflow      Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@map("workflow_triggers")
}

model Variable {
  id          String   @id @default(cuid())
  namespaceId String
  key         String
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  namespace   Namespace @relation(fields: [namespaceId], references: [id], onDelete: Cascade)

  @@unique([namespaceId, key])
  @@map("variables")
}

model Secret {
  id          String   @id @default(cuid())
  namespaceId String
  key         String
  value       String  // encrypted
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  namespace   Namespace @relation(fields: [namespaceId], references: [id], onDelete: Cascade)

  @@unique([namespaceId, key])
  @@map("secrets")
}
