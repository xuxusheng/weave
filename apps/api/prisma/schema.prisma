generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Workflow {
  id          String   @id @default(cuid())
  name        String
  namespace   String   @default("company.team")
  description String?
  nodes       Json     @default("[]")
  edges       Json     @default("[]")
  inputs      Json     @default("[]")
  yaml        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("workflows")
}
