{
  "compilerOptions": {
    "target": "ES2023",
    "module": "Preserve",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "useUnknownInCatchVariables": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false,
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    // Workaround: @kestra-io/kestra-sdk exports 字段缺少 types 条件
    // 已向官方提 PR，合入后可移除
    "paths": {
      "@kestra-io/kestra-sdk": ["./node_modules/@kestra-io/kestra-sdk/dist/KestraClient.d.ts"]
    }
  },
  "include": ["src"]
}
