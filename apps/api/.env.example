# Database
DATABASE_URL="postgresql://user:password@localhost:5432/weave"

# Kestra
KESTRA_URL="http://localhost:8080"

# 认证方式（二选一，推荐使用 Token）
# 推荐：使用 API Token 或 Service Account Token
KESTRA_TOKEN=""
# 回退：Basic Auth
# KESTRA_USERNAME="admin"
# KESTRA_PASSWORD="admin"

# 可选：多租户
# KESTRA_TENANT="main"

# OpenTelemetry (SigNoz / Jaeger)
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
# 可选: 认证 header，格式 key=value,key=value
# OTEL_EXPORTER_OTLP_HEADERS="Authorization=Bearer <token>"
